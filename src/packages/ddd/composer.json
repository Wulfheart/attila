{
    "name": "wulfheart/ddd",
    "description": "",
    "keywords": [
        "wulfheart",
        "ddd"
    ],
    "license": "GPL-2.0-or-later",
    "type": "library",
    "authors": [
        {
            "name": "Alex",
            "email": "alex.f.wulf@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^4.0",
        "phpunit/phpunit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Wulfheart\\DDD\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wulfheart\\DDD\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wulfheart\\DDD\\DDDServiceProvider"
            ],
            "aliases": {
                "Dmake": "Wulfheart\\DDD\\DDDFacade"
            }
        }
    }
}
